<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8" />
        <title>Ibexa DXP</title>
        {{ encore_entry_link_tags('ibexa-admin-ui-security-base-css', null, 'ibexa') }}
        <link rel="icon" type="image/x-icon" href="{{ asset('bundles/ibexaadminui/img/favicon.ico') }}" />

        <script src="{{ asset('bundles/ibexaadminuiassets/vendors/@popperjs/core/dist/umd/popper.min.js') }}"></script>
        <script src="{{ asset('bundles/ibexaadminuiassets/vendors/bootstrap/dist/js/bootstrap.min.js') }}"></script>
    </head>
    <body class="ibexa-login-view">
        <div class="ibexa-main-container">
            <div class="ibexa-login">
                <div class="ibexa-login__sidebar" aria-hidden="true">
                    <ul class="ibexa-login__sidebar-nav">
                        <li>
                            <a class="ibexa-login__sidebar-link" href="https://www.ibexa.co/" target="_blank" rel="noopener noreferrer">
                                <img class="ibexa-login__sidebar-link-icon" src="{{ asset('bundles/ibexaadminui/img/brands/ibexa-icon.svg') }}" alt="ibexa" />
                                <span class="ibexa-login__sidebar-link-text">Ibexa</span>
                            </a>
                        </li>
                        <li>
                            <a class="ibexa-login__sidebar-link" href="https://www.ibexa.co/orchestration/cohesivo" target="_blank" rel="noopener noreferrer">
                                <img class="ibexa-login__sidebar-link-icon" src="{{ asset('bundles/ibexaadminui/img/brands/cohesivo-icon.svg') }}" alt="cohesivo" />
                                <span class="ibexa-login__sidebar-link-text">Cohesivo</span>
                            </a>
                        </li>
                        <li>
                            <a class="ibexa-login__sidebar-link" href="https://www.actito.com/" target="_blank" rel="noopener noreferrer">
                                <img class="ibexa-login__sidebar-link-icon" src="{{ asset('bundles/ibexaadminui/img/brands/actito-icon.svg') }}" alt="actito" />
                                <span class="ibexa-login__sidebar-link-text">Actito</span>
                            </a>
                        </li>
                        <li>
                            <a class="ibexa-login__sidebar-link" href="https://qualifio.com/" target="_blank" rel="noopener noreferrer">
                                <img class="ibexa-login__sidebar-link-icon" src="{{ asset('bundles/ibexaadminui/img/brands/qualifio-icon.svg') }}" alt="qualifio" />
                                <span class="ibexa-login__sidebar-link-text">Qualifio</span>
                            </a>
                        </li>
                        <li>
                            <a class="ibexa-login__sidebar-link" href="https://www.quable.com/" target="_blank" rel="noopener noreferrer">
                                <img class="ibexa-login__sidebar-link-icon" src="{{ asset('bundles/ibexaadminui/img/brands/quable-icon.svg') }}" alt="quable" />
                                <span class="ibexa-login__sidebar-link-text">Quable</span>
                            </a>
                        </li>
                        <li>
                            <a class="ibexa-login__sidebar-link" href="https://www.raptorservices.com/" target="_blank" rel="noopener noreferrer">
                                <img class="ibexa-login__sidebar-link-icon" src="{{ asset('bundles/ibexaadminui/img/brands/raptor-icon.svg') }}" alt="raptor" />
                                <span class="ibexa-login__sidebar-link-text">Raptor</span>
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="ibexa-login__panel">
                    <div class="ibexa-login__actions">
                        <img class="ibexa-login__logo" src="{{ asset('bundles/ibexaadminui/img/cohesivo-logo-alt.svg') }}" alt="ibexa" />
                        <div class="ibexa-login__form">
                            {%- block content -%} {%- endblock content -%}
                        </div>
                        <div class="ibexa-login__panel-footer">
                            <a href="https://doc.ibexa.co/en/latest/" target="_blank" rel="noopener noreferrer">{{ 'base.documentation'|trans|desc('Documentation') }}</a>
                            <a href="https://support.ibexa.co/login" target="_blank" rel="noopener noreferrer">{{ 'base.support'|trans|desc('Support') }}</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {% if app.request.locale == 'ach-UG' %}
            <script type="text/javascript">
                var _jipt = [];
                _jipt.push(['project', 'ibexa-dxp']);
            </script>
            <script type="text/javascript" src="//cdn.crowdin.com/jipt/jipt.js"></script>
        {% endif %}
    </body>
</html>
